# Podfile — place this file inside the studyOs/ folder
# (same directory as StudyOs.xcodeproj)
#
# After adding this file, run:   cd studyOs && pod install
# Always open StudyOs.xcworkspace, NOT StudyOs.xcodeproj

platform :ios, '15.0'
inhibit_all_warnings!
use_frameworks!

target 'studyOs' do
  # Add your CocoaPods dependencies here.
  # If you have none, leave this block empty — CocoaPods will still
  # generate the .xcworkspace file that the build needs.

  # Examples (uncomment if needed):
  # pod 'Alamofire', '~> 5.8'
  # pod 'SDWebImage', '~> 5.18'

  target 'studyOsTests' do
    inherit! :search_paths
  end

  target 'studyOsUITests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
      config.build_settings['CODE_SIGNING_ALLOWED'] = 'NO'
    end
  end
end
